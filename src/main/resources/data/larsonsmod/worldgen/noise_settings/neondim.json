{
  "sea_level": -64,
  "disable_mob_generation": false,
  "aquifers_enabled": false,
  "ore_veins_enabled": true,
  "legacy_random_source": false,
  "default_block": {
    "Name": "larsonsmod:neon_stone"
  },
  "default_fluid": {
    "Name": "minecraft:water",
    "Properties": {
      "level": "0"
    }
  },
  "noise": {
    "min_y": -64,
    "height": 384,
    "size_horizontal": 1,
    "size_vertical": 2
  },
  "noise_router": {
    "barrier": 0,
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
    "lava": 0,
    "temperature": {
      "type": "minecraft:shifted_noise",
      "noise": "minecraft:temperature",
      "xz_scale": 0.25,
      "y_scale": 0,
      "shift_x": "minecraft:shift_x",
      "shift_y": 0,
      "shift_z": "minecraft:shift_z"
    },
    "vegetation": {
      "type": "minecraft:shifted_noise",
      "noise": "minecraft:vegetation",
      "xz_scale": 0.25,
      "y_scale": 0,
      "shift_x": "minecraft:shift_x",
      "shift_y": 0,
      "shift_z": "minecraft:shift_z"
    },
    "continents": "minecraft:overworld/continents",
    "erosion": "minecraft:overworld/erosion",
    "depth": "minecraft:overworld/depth",
    "ridges": "minecraft:overworld/ridges",
    "initial_density_without_jaggedness": {
      "type": "minecraft:mul",
      "argument1": 4,
      "argument2": {
        "type": "minecraft:quarter_negative",
        "argument": {
          "type": "minecraft:mul",
          "argument1": {
            "type": "minecraft:add",
            "argument1": "minecraft:overworld/depth",
            "argument2": {
              "type": "minecraft:mul",
              "argument1": {
                "type": "minecraft:noise",
                "noise": "minecraft:jagged",
                "xz_scale": 1500,
                "y_scale": 0
              },
              "argument2": {
                "type": "minecraft:clamp",
                "input": {
                  "type": "minecraft:add",
                  "argument1": "minecraft:overworld/depth",
                  "argument2": 0.5
                },
                "min": 0,
                "max": 0.5
              }
            }
          },
          "argument2": {
            "type": "minecraft:cache_once",
            "argument": {
              "type": "minecraft:spline",
              "spline": {
                "coordinate": "minecraft:overworld/ridges",
                "points": [
                  { "location": -1.0, "value": 1.2, "derivative": 0 },
                  { "location": -0.5, "value": 2.5, "derivative": 0 },
                  { "location": 0.0, "value": 1.8, "derivative": 0 },
                  { "location": 0.5, "value": 2.5, "derivative": 0 },
                  { "location": 1.0, "value": 1.2, "derivative": 0 }
                ]
              }
            }
          }
        }
      }
    },
    "final_density": {
      "type": "minecraft:squeeze",
      "argument": {
        "type": "minecraft:mul",
        "argument1": 0.64,
        "argument2": {
          "type": "minecraft:interpolated",
          "argument": {
            "type": "minecraft:blend_density",
            "argument": {
              "type": "minecraft:max",
              "argument1": {
                "comment_ground": "Ground terrain: rolling hills with void below",
                "type": "minecraft:add",
                "argument1": {
                  "type": "minecraft:add",
                  "argument1": {
                    "type": "minecraft:mul",
                    "argument1": 4,
                    "argument2": {
                      "type": "minecraft:quarter_negative",
                      "argument": {
                        "type": "minecraft:mul",
                        "argument1": {
                          "type": "minecraft:add",
                          "argument1": "minecraft:overworld/depth",
                          "argument2": {
                            "type": "minecraft:mul",
                            "argument1": {
                              "type": "minecraft:noise",
                              "noise": "minecraft:jagged",
                              "xz_scale": 1500,
                              "y_scale": 0
                            },
                            "argument2": {
                              "type": "minecraft:clamp",
                              "input": {
                                "type": "minecraft:add",
                                "argument1": "minecraft:overworld/depth",
                                "argument2": 0.5
                              },
                              "min": 0,
                              "max": 0.5
                            }
                          }
                        },
                        "argument2": {
                          "type": "minecraft:cache_once",
                          "argument": {
                            "type": "minecraft:spline",
                            "spline": {
                              "coordinate": "minecraft:overworld/ridges",
                              "points": [
                                { "location": -1.0, "value": 1.2, "derivative": 0 },
                                { "location": -0.5, "value": 2.5, "derivative": 0 },
                                { "location": 0.0, "value": 1.8, "derivative": 0 },
                                { "location": 0.5, "value": 2.5, "derivative": 0 },
                                { "location": 1.0, "value": 1.2, "derivative": 0 }
                              ]
                            }
                          }
                        }
                      }
                    }
                  },
                  "argument2": {
                    "comment_bottom_void": "Carve void below Y=20: gradient subtracts density",
                    "type": "minecraft:y_clamped_gradient",
                    "from_y": -20,
                    "to_y": 20,
                    "from_value": -6.0,
                    "to_value": 0.0
                  }
                },
                "argument2": {
                  "comment_top_cap": "Kill ground terrain above Y=120 so floating islands have clear sky",
                  "type": "minecraft:y_clamped_gradient",
                  "from_y": 100,
                  "to_y": 130,
                  "from_value": 0.0,
                  "to_value": -4.0
                }
              },
              "argument2": {
                "comment_floating_islands": "Floating island blobs between Y=150-250",
                "type": "minecraft:add",
                "argument1": {
                  "type": "minecraft:add",
                  "argument1": {
                    "comment_3d_blob_noise": "3D noise creates island blob shapes",
                    "type": "minecraft:noise",
                    "noise": "minecraft:cave_layer",
                    "xz_scale": 0.6,
                    "y_scale": 2.0
                  },
                  "argument2": {
                    "comment_offset": "Offset makes most values negative (air), only peaks are solid",
                    "type": "minecraft:mul",
                    "argument1": -0.55,
                    "argument2": 1
                  }
                },
                "argument2": {
                  "type": "minecraft:add",
                  "argument1": {
                    "comment_lower_ramp": "Ramp from void into island band",
                    "type": "minecraft:y_clamped_gradient",
                    "from_y": 140,
                    "to_y": 175,
                    "from_value": -3.0,
                    "to_value": 0.0
                  },
                  "argument2": {
                    "comment_upper_ramp": "Ramp from island band back to void",
                    "type": "minecraft:y_clamped_gradient",
                    "from_y": 230,
                    "to_y": 270,
                    "from_value": 0.0,
                    "to_value": -3.0
                  }
                }
              }
            }
          }
        }
      }
    },
    "vein_toggle": 0,
    "vein_ridged": 0,
    "vein_gap": 0
  },
  "spawn_target": [],
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "offset": 0,
          "surface_type": "floor",
          "add_surface_depth": false,
          "secondary_depth_range": 0
        },
        "then_run": {
          "type": "minecraft:condition",
          "if_true": {
            "type": "minecraft:water",
            "offset": -1,
            "surface_depth_multiplier": 0,
            "add_stone_depth": false
          },
          "then_run": {
            "type": "minecraft:block",
            "result_state": {
              "Name": "minecraft:grass_block"
            }
          }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "offset": 0,
          "surface_type": "floor",
          "add_surface_depth": true,
          "secondary_depth_range": 0
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": {
            "Name": "minecraft:dirt"
          }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "offset": 0,
          "surface_type": "ceiling",
          "add_surface_depth": false,
          "secondary_depth_range": 0
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": {
            "Name": "larsonsmod:neon_stone"
          }
        }
      }
    ]
  }
}
